# View ④ — DevSecOps supply chain
# DoD DevSecOps Reference Design "Figure 2" grammar:
#   • Phase row with control-gate diamonds (◆) at each Go/No-Go promotion point
#   • Full-width Continuous Security band (CMMC-mapped, grounded in security.yml)
#   • release.yml supply chain: native multi-arch build → sign → verify → GHCR
# Sources: cosmos-v2/.github/workflows/security.yml + release.yml
...@_theme

direction: right

# ─── Title ────────────────────────────────────────────────────────────────────
title: "cosmos-v2 — DevSecOps Supply Chain\n(View ④: DoD Fig-2 pipeline · CMMC L2 · SLSA Build L2/L3)" {
  near: top-center
  class: title
}

# ─── Phase row: Plan ◆ Build ◆ Test ◆ Release ◆ Deploy ───────────────────────
# Five phases with four control-gate diamonds between each adjacent pair.
phase-plan: Plan { class: ci }
gate-1: "Go/No-Go ◆" { class: gate }
phase-build: Build { class: ci }
gate-2: "Go/No-Go ◆" { class: gate }
phase-test: Test { class: ci }
gate-3: "Go/No-Go ◆" { class: gate }
phase-release: Release { class: ci }
gate-4: "Go/No-Go ◆" { class: gate }
phase-deploy: Deploy { class: ci }

phase-plan -> gate-1: "code ready"
gate-1 -> phase-build: "approved"
phase-build -> gate-2: "build clean"
gate-2 -> phase-test: "approved"
phase-test -> gate-3: "tests pass"
gate-3 -> phase-release: "approved"
phase-release -> gate-4: "artifact signed"
gate-4 -> phase-deploy: "approved"

# ─── Continuous Security Automation band ──────────────────────────────────────
# Full-width boundary containing the 8 CMMC-mapped security gates from security.yml.
# Control IDs ground each gate to NIST 800-171 requirements.
security-band: "Continuous Security Automation  (runs on every push / PR — security.yml)" {
  class: boundary

  # Gate 1 — SAST / CodeQL  ·  800-171 3.11.2 / 3.14.1
  sg-codeql: "SAST / CodeQL\n(JS/TS; SARIF evidence)" { class: ci }
  sg-codeql-note: "3.11.2 / 3.14.1\nHard gate" { class: note }

  # Gate 2 — SCA / Trivy + OSV  ·  800-171 3.11.2 (HARD on Critical)
  sg-sca: "SCA / Trivy+OSV\n(lockfile + fs; HARD on Critical)" { class: ci }
  sg-sca-note: "3.11.2\nPOA&M on High" { class: note }

  # Gate 3 — Secrets / gitleaks  ·  800-171 3.5.1 / 3.5.2 (HARD — any finding fails)
  sg-secrets: "secrets / gitleaks\n(full history; pinned CLI)" { class: ci }
  sg-secrets-note: "3.5.1 / 3.5.2\nHard gate" { class: note }

  # Gate 4 — Image CVE / Trivy image  ·  800-171 3.11.2 (HARD on Critical)
  sg-image-cve: "image-CVE / Trivy\n(single cosmos-v2 image; HARD)" { class: ci }
  sg-image-cve-note: "3.11.2\nHard on Critical" { class: note }

  # Gate 5 — IaC / hadolint + Checkov  ·  800-171 3.4.1 / 3.4.2 (Info — never blocks)
  sg-iac: "IaC / hadolint+Checkov\n(Dockerfile + manifests; Info)" { class: ci }
  sg-iac-note: "3.4.1 / 3.4.2\nInfo (never blocks)" { class: note }

  # Gate 6 — SBOM / Syft  ·  800-171 3.4.x (component inventory)
  sg-sbom: "SBOM / Syft\n(SPDX-JSON; OCI-attached)" { class: ci }
  sg-sbom-note: "3.4.x\nComponent inventory" { class: note }

  # Gate 7 — sign + provenance  ·  800-171 3.4.x / 3.14.x
  sg-sign: "sign + provenance\n(cosign keyless + KMS; SLSA attest)" { class: ci }
  sg-sign-note: "3.4.x / 3.14.x\nIntegrity + supply chain" { class: note }

  # Gate 8 — config assertions  ·  800-171 3.1.1 / 3.4.x (HARD — SHA-pin enforcement)
  sg-config: "config-assertions\n(SHA-pin · E2E-auth · control-coverage)" { class: ci }
  sg-config-note: "3.1.1 / 3.4.x\nHard gate" { class: note }

  # Note captions associated with gates
  sg-codeql -> sg-codeql-note: "" { class: alt }
  sg-sca -> sg-sca-note: "" { class: alt }
  sg-secrets -> sg-secrets-note: "" { class: alt }
  sg-image-cve -> sg-image-cve-note: "" { class: alt }
  sg-iac -> sg-iac-note: "" { class: alt }
  sg-sbom -> sg-sbom-note: "" { class: alt }
  sg-sign -> sg-sign-note: "" { class: alt }
  sg-config -> sg-config-note: "" { class: alt }
}

# ─── release.yml supply chain ─────────────────────────────────────────────────
# Sequence: native multi-arch build → merge manifest → Syft SBOM → cosign
# keyless + KMS → SLSA attest → verify-after-sign ◆ → GHCR artifact
supply-chain: "release.yml  supply chain  (triggers on v* tag)" {
  class: boundary

  # Build step — no QEMU; native amd64 + arm64 runners, push by digest
  sc-build: "native multi-arch build\n(no QEMU · amd64+arm64 by digest)" { class: ci }

  # Merge manifests — assemble multi-arch manifest list, apply SemVer + :latest tags
  sc-merge: "merge manifest\n(imagetools · SemVer + :latest + :sha-<sha>)" { class: ci }

  # SBOM — Syft SPDX-JSON of merged runtime image, gate 6
  sc-sbom: "Syft SBOM\n(SPDX-JSON · OCI-attached)" { class: ci }

  # Sign — cosign keyless (OIDC → Fulcio/Rekor) always; KMS additionally
  sc-cosign: "cosign keyless + KMS\n(OIDC → Fulcio/Rekor + KMS when configured)" { class: ci }

  # SLSA attestation — bound to merged runtime manifest digest
  sc-slsa: "SLSA attest\n(actions/attest-build-provenance)" { class: ci }

  # verify-after-sign gate — re-resolve digest, confirm sig present; re-sign if missing
  sc-verify: "verify-after-sign ◆\n(re-resolve digest · fail if unverifiable)" { class: gate }

  # Final artifact — GHCR: images (runtime + migrate + postgres) + OCI chart + UDS bundle
  sc-ghcr: "GHCR: images · OCI chart · UDS bundle\n(cosmos-v2 · cosmos-v2-migrate · cosmos-v2-postgres)" { class: artifact }

  # Supply chain flow edges
  sc-build -> sc-merge: "per-arch digests"
  sc-merge -> sc-sbom: "merged digest"
  sc-sbom -> sc-cosign: "SBOM attached"
  sc-cosign -> sc-slsa: "sig attached"
  sc-slsa -> sc-verify: "provenance attached"
  sc-verify -> sc-ghcr: "verified"
}

# SLSA spine caption
slsa-note: "SLSA: Source → Build → Package → Consumer · Build L2/L3" { class: note }

# ─── Externals (de-emphasized) ────────────────────────────────────────────────
# Fulcio + Rekor are the public Sigstore transparency infrastructure;
# referenced from the cosign sign step in release.yml
fulcio: "Fulcio\n(OIDC cert authority)" { class: external }
rekor: "Rekor\n(WORM transparency log)" { class: external }

# Edges from cosign to Sigstore infrastructure
supply-chain.sc-cosign -> fulcio: "OIDC → cert"
supply-chain.sc-cosign -> rekor: "inclusion proof"

# ─── Phase row → supply chain cross-links ─────────────────────────────────────
# Tie phase row to supply-chain bands to show what fires in each phase
phase-build -> supply-chain.sc-build: "triggers build"
phase-release -> supply-chain.sc-cosign: "sign + publish"

# ─── Security band → supply chain cross-links ─────────────────────────────────
security-band.sg-sbom -> supply-chain.sc-sbom: "gate 6 → release SBOM" { class: obs }
security-band.sg-sign -> supply-chain.sc-cosign: "gate 7 → sign step" { class: obs }

# ─── Legend ──────────────────────────────────────────────────────────────────
legend: "Legend" {
  near: bottom-center
  class: boundary

  l-ci: "CI step / security gate" { class: ci }
  l-artifact: "OCI artifact (GHCR)" { class: artifact }
  l-gate: "control gate ◆ (Go/No-Go)" { class: gate }
  l-boundary: "pipeline band / boundary" { class: boundary }
  l-external: "external service (de-emphasized)" { class: external }
  l-note: "annotation / control-id caption" { class: note }
  l-obs: "cross-band reference" { class: obs }
  l-alt: "note association" { class: alt }
}
